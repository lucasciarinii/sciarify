<Window x:Class="Esercizio_23_Sciarfy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Esercizio_23_Sciarfy"
        mc:Ignorable="d"
        Title="Sciarfy" Height="850" Width="1100" Background="Transparent" WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen" FontFamily="Poppins">

    <Window.Resources>
        <Style x:Key="transparentBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="playlist" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="#83fb44">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="playButton" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="200" Background="#83fb44">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        <Style x:Key="backNextSongButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="200" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="songSlider" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="listBoxItem" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="6" BorderThickness="20" Background="#2c312e" BorderBrush="#2c312e">
        <Grid ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="39*" />
                <RowDefinition Height="4*" />
            </Grid.RowDefinitions>

            <!-- LOGO SECTION -->
            <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
                <Image Source="/images/AI_SpotifyLogo.png" Height="42" Margin="10 0 10 0" />
                <TextBlock VerticalAlignment="Center" FontSize="28" FontWeight="Medium" Foreground="White">Sciarify</TextBlock>
            </StackPanel>

            <!-- SIDEBAR -->
            <Grid Grid.Column="0" Grid.Row="1" Margin="10 0 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="115px" />
                    <RowDefinition Height="10px" />
                    <RowDefinition Height="5*" />
                </Grid.RowDefinitions>

                <!--NAVIGATION-->
                <StackPanel Orientation="Vertical" Margin="10 30 0 0">
                    <Button Style="{StaticResource transparentBtn}" HorizontalAlignment="Left" Margin="0 0 0 15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Image Source="/images/libreriaIcon.png" Height="20" Margin="0 0 15 0" />
                            <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Light" Foreground="White" TextDecorations="Underline"><Run Text="Libreria"/></TextBlock>
                        </StackPanel>
                    </Button>
                    <Button x:Name="GoFavouritePageBTN" Style="{StaticResource transparentBtn}" HorizontalAlignment="Left" Click="GoFavouritePageBTN_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Image Source="/images/favouriteIcon.png" Height="20" Margin="0 0 15 0" />
                            <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Light" Foreground="White"><Run Text="Preferiti"/></TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!--DIVISION BAR-->
                <Rectangle Grid.Row="1" Fill="#FF848484" Height="1.5px" Width="220px" HorizontalAlignment="Left" Margin="10 0 0 0"/>

                <!--PLAYLIST-->
                <StackPanel Orientation="Vertical" Grid.Row="2" Margin="7 20 10 7">
                    <Button Name="RandomPlaylistBTN" Style="{StaticResource playlist}" Height="32" Width="220" HorizontalAlignment="Left" Click="RandomPlaylistBTN_Click">Playlist</Button>

                    <ListBox x:Name="Playlist_ListBox" ItemContainerStyle="{StaticResource listBoxItem}" Background="Transparent" SelectionMode="Extended" Margin="0 20 0 10" BorderBrush="{x:Null}" ScrollViewer.VerticalScrollBarVisibility="Hidden" SelectionChanged="Playlist_ListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0 0 0 10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="4*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                    </Grid.RowDefinitions>


                                    <Ellipse Width="34" Height="34" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding PathImg}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Text="{Binding Nome}" Grid.Column="1" FontSize="12" FontWeight="Regular" Foreground="White" VerticalAlignment="Center" />
                                    <TextBlock Text="" Margin="40 0 0 0" Grid.Column="2" FontSize="12" FontWeight="Regular" Foreground="White" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Border CornerRadius="15" BorderThickness="0" Background="#0c0c11" BorderBrush="#2c312e" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" Margin="0 0 -30 -30">
                <Grid ShowGridLines="False" Margin="45 5 45 35">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8*" />
                        <RowDefinition Height="4*" />
                    </Grid.RowDefinitions>

                    <!--SUGGESTED SONG-->
                    <TextBlock Foreground="#4fa93f" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="70 0 0 0">Consigliata</TextBlock>
                    <Border CornerRadius="20" Grid.Row="1" Height="330" Width="600" Margin="0 -125 0 0">
                        <Canvas Height="330" Width="600">
                            <Image Source="/playlists/firstCover.png" Stretch="UniformToFill"  Height="330" Width="600"/>
                            <TextBlock Foreground="White" FontSize="35" Canvas.Bottom="80" Canvas.Left="20" Canvas.ZIndex="1" Text="Stayin' Alive" FontWeight="SemiBold"/>
                            <TextBlock Foreground="#80fa47" FontSize="13" Canvas.Bottom="63" Canvas.Left="20" Canvas.ZIndex="1" Text="Bee Gees" FontWeight="Regular"/>
                            <Button x:Name="PlaySuggested" Style="{StaticResource playButton}" Height="40" Width="40" Canvas.Bottom="17" Canvas.Left="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="PlaySuggested_Click">
                                <Image x:Name="SuggestedPlayIcon" Source="/images/playIcon.png" Height="17" />
                            </Button>
                            <ProgressBar x:Name="progressBar" Height="8" Width="400" Canvas.Bottom="10" Canvas.Left="100" Value="0" Maximum="1" MouseLeftButtonDown="ProgressBar_MouseLeftButtonDown" MouseLeftButtonUp="ProgressBar_MouseLeftButtonUp" Background="#FF616161" Foreground="#FF7EFC47" BorderBrush="{x:Null}" />
                        </Canvas>
                    </Border>
                    <MediaElement x:Name="mediaElement" Source="" Volume="0.1" LoadedBehavior="Manual" MediaEnded="MediaElement_MediaEnded" MediaOpened="MediaElement_MediaOpened" />
                    
                    <!--LISTS OF SONGS-->
                    <TextBlock x:Name="PlaylistName_TextBlock" Grid.Row="1" Foreground="#4fa93f" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="70 300 0 0" Text="Brani:"></TextBlock>
                    <ListBox Name="Song_ListBox" Width="750" ItemContainerStyle="{StaticResource listBoxItem}" Grid.Row="2" Background="Transparent" SelectionMode="Extended" Margin="0 -40 0 10" BorderBrush="{x:Null}" ScrollViewer.VerticalScrollBarVisibility="Hidden" SelectionChanged="Song_ListBox_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Width="640" ItemWidth="160" ItemHeight="160" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10">
                                    <Image Name="SongCover" Source="{Binding PathIMG}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        
                    </ListBox>

                </Grid>
            </Border>

            <!--SLIDER PLAYER-->
            <Border Grid.Column="1" Grid.Row="2" Background="#1f1e21" CornerRadius="20" Margin="30 0 0 0">
                <Grid Grid.Column="1" Grid.Row="2" Margin="10 0 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="11*"/>
                        <ColumnDefinition Width="18*" />
                        <ColumnDefinition Width="10*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <!--SONG DETAILS-->
                    <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal">
                        <Image x:Name="MainSongCover" Source="/songs/covers/avicii_wakemeup_cover.jpg" Height="45" Margin="10 0 10 0" />
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock x:Name="MainSongTitle" Foreground="White" FontWeight="SemiBold" FontSize="14">Wake me Up</TextBlock>
                            <TextBlock x:Name="MainSongArtist" Foreground="White" FontWeight="Normal" FontSize="11">Avicii</TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!--SLIDER-->
                    <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Margin="0 5 0 5" Orientation="Vertical" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BackSong" Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"  Style="{StaticResource backNextSongButton}" Height="35" Width="35" Canvas.Bottom="17" Canvas.Left="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="BackSong_Click">
                                <Image Source="/images/backSongIcon.png" Height="19" />
                            </Button>
                            <Button x:Name="PlayMain" Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Margin="10 0 10 0" Style="{StaticResource playButton}" Height="35" Width="35" Canvas.Bottom="17" Canvas.Left="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="PlayMain_Click">
                                <Image Name="PlayMainIcon" Source="/images/playIcon.png" Height="15" />
                            </Button>
                            <Button x:Name="NextSong" Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"  Style="{StaticResource backNextSongButton}" Height="35" Width="35" Canvas.Bottom="17" Canvas.Left="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="NextSong_Click">
                                <Image Source="/images/nextSongIcon.png" Height="19" />
                            </Button>
                        </StackPanel>
                        
                        
                        <ProgressBar x:Name="MainProgressBar" Height="6" Margin="0 10 0 0" Width="350" Canvas.Bottom="10" Canvas.Left="100" Value="0" Maximum="1" Background="#FF616161" Foreground="#FF7EFC47" BorderBrush="{x:Null}" MouseLeftButtonDown="MainProgressBar_MouseLeftButtonDown" MouseLeftButtonUp="MainProgressBar_MouseLeftButtonUp" />

                        <MediaElement Name="MainPlayer" Source="" Volume="0.1" LoadedBehavior="Manual" MediaEnded="MainPlayer_MediaEnded" MediaOpened="MainPlayer_MediaOpened" />
                    </StackPanel>

                    <!--FAVOURITE-->
                    <Button x:Name="FavouriteBtn" Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"  Style="{StaticResource transparentBtn}" Height="40" Width="40" Canvas.Bottom="17" Canvas.Left="20" Margin="0 0 10 0" HorizontalAlignment="Right" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="FavouriteBtn_Click">
                        <Image Name="FavouriteIcon" Source="/images/favouriteNO.png" Height="20" />
                    </Button>
                </Grid>
            </Border>

            <!--CREDITS-->
            <TextBlock Grid.Column="0" Grid.Row="3" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10 0 0 0" FontWeight="light" Foreground="#FFBBBBBB">Sciarfy © Luca Sciarini - 2023</TextBlock>
        </Grid>
    </Border>
</Window>
